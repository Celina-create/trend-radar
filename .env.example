# Required for LLM (use Vercel AI Gateway or direct OpenAI key)
# Get from: https://vercel.com/dashboard/ai-gateway
AI_GATEWAY_API_KEY=

# Or, alternatively, direct provider key
OPENAI_API_KEY=

# Optional: cron secret to protect /api/cron/batch
CRON_SECRET=

# Optional: Vercel KV (auto-injected by Vercel when KV is provisioned)
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
